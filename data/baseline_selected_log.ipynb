   "id": "c064b87c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Raw geometric YoY Revenue growth : 0.9620  (-3.80%/yr)\n",
      "Raw geometric YoY COGS    growth : 0.9605  (-3.95%/yr)\n"
     ]
    }
   ],
   "source": [
    "# --- Raw YoY growth (geometric mean, 2013–2022) ---\n",
    "full_years = annual.loc[2013:2022].copy()\n",
    "\n",
    "yoy_rev  = full_years['Revenue'].pct_change().dropna()\n",
    "yoy_cogs = full_years['COGS'].pct_change().dropna()\n",
    "\n",
    "raw_growth_rev  = (1 + yoy_rev).prod() ** (1 / len(yoy_rev))\n",
    "raw_growth_cogs = (1 + yoy_cogs).prod() ** (1 / len(yoy_cogs))\n",
    "\n",
    "print(f'Raw geometric YoY Revenue growth : {raw_growth_rev:.4f}  ({(raw_growth_rev-1)*100:.2f}%/yr)')\n",
    "print(f'Raw geometric YoY COGS    growth : {raw_growth_cogs:.4f}  ({(raw_growth_cogs-1)*100:.2f}%/yr)')"
   ]
  },
