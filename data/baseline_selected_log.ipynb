    "metadata": {},
    "source": [
     "## 11.6 — Time-Series Cross Validation\n",
     "Evaluate tree-based models with 5-fold TimeSeriesSplit and compare against the single-split validation MAPE."
    ]
   },
   {
    "cell_type": "code",
    "execution_count": null,
    "id": "b2c3d4e5",
    "metadata": {},
    "outputs": [],
    "source": [
     "from sklearn.model_selection import TimeSeriesSplit\n",
     "\n",
     "required = [\n",
     "    \"X\", \"y\", \"y_log\",\n",
     "    \"rf_best_params\", \"et_best_params\",\n",
     "    \"lgb_best_params_rev\", \"lgb_best_params_cogs\",\n",
     "    \"xgb_best_params_rev\", \"xgb_best_params_cogs\",\n",
     "]\n",
     "missing = [n for n in required if n not in globals()]\n",
     "if missing:\n",
     "    raise ValueError(\"Missing variables: %s. Run Sections 8-11 first.\" % \", \".join(missing))\n",
     "\n",
     "if \"lgb_base_params\" not in globals():\n",
     "    lgb_base_params = {\"objective\": \"regression\", \"metric\": \"mape\", \"verbosity\": -1}\n",
     "if \"xgb_base_params\" not in globals():\n",
     "    xgb_base_params = {\"objective\": \"reg:squarederror\", \"eval_metric\": \"mape\", \"seed\": 42, \"nthread\": -1}\n",
     "\n",
     "def mape_cv(actual, pred):\n",
     "    actual = np.asarray(actual, dtype=float)\n",
     "    pred = np.asarray(pred, dtype=float)\n",
     "    eps = 1e-9\n",
     "    return float(np.mean(np.abs(actual - pred) / (np.abs(actual) + eps)))\n",
     "\n",
     "tscv = TimeSeriesSplit(n_splits=5)\n",
     "cv_records = []\n",
     "\n",
     "for fold, (tr_idx, val_idx) in enumerate(tscv.split(X), 1):\n",
     "    X_tr, X_va = X.iloc[tr_idx], X.iloc[val_idx]\n",
     "    y_tr, y_va = y.iloc[tr_idx], y.iloc[val_idx]\n",
     "    yl_tr, yl_va = y_log.iloc[tr_idx], y_log.iloc[val_idx]\n",
     "\n",
     "    # Random Forest\n",
     "    rf_m = RandomForestRegressor(n_jobs=-1, random_state=42, **rf_best_params)\n",
     "    rf_m.fit(X_tr, yl_tr)\n",
     "    p = rf_m.predict(X_va)\n",
     "    pr = pd.DataFrame(p, columns=[\"Revenue\", \"COGS\"])\n",
     "    pr[\"Revenue\"] = np.maximum(np.expm1(pr[\"Revenue\"]), 0.0)\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"rf\", \"target\": \"Revenue\", \"mape\": mape_cv(y_va[\"Revenue\"], pr[\"Revenue\"])})\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"rf\", \"target\": \"COGS\", \"mape\": mape_cv(y_va[\"COGS\"], pr[\"COGS\"])})\n",
     "\n",
     "    # ExtraTrees\n",
     "    et_m = ExtraTreesRegressor(n_jobs=-1, random_state=42, **et_best_params)\n",
     "    et_m.fit(X_tr, yl_tr)\n",
     "    p = et_m.predict(X_va)\n",
     "    pr = pd.DataFrame(p, columns=[\"Revenue\", \"COGS\"])\n",
     "    pr[\"Revenue\"] = np.maximum(np.expm1(pr[\"Revenue\"]), 0.0)\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"et\", \"target\": \"Revenue\", \"mape\": mape_cv(y_va[\"Revenue\"], pr[\"Revenue\"])})\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"et\", \"target\": \"COGS\", \"mape\": mape_cv(y_va[\"COGS\"], pr[\"COGS\"])})\n",
     "\n",
     "    # LightGBM Revenue\n",
     "    dtrain = lgb.Dataset(X_tr, label=yl_tr[\"Revenue\"])\n",
     "    dval = lgb.Dataset(X_va, label=yl_va[\"Revenue\"], reference=dtrain)\n",
     "    m = lgb.train(\n",
     "        {**lgb_base_params, **lgb_best_params_rev},\n",
     "        dtrain,\n",
     "        num_boost_round=2000,\n",
     "        valid_sets=[dval],\n",
     "        callbacks=[lgb.early_stopping(50, verbose=False)],\n",
     "    )\n",
     "    pr = np.maximum(np.expm1(m.predict(X_va)), 0.0)\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"lgb\", \"target\": \"Revenue\", \"mape\": mape_cv(y_va[\"Revenue\"], pr)})\n",
     "\n",
     "    # LightGBM COGS\n",
     "    dtrain = lgb.Dataset(X_tr, label=y_tr[\"COGS\"])\n",
     "    dval = lgb.Dataset(X_va, label=y_va[\"COGS\"], reference=dtrain)\n",
     "    m = lgb.train(\n",
     "        {**lgb_base_params, **lgb_best_params_cogs},\n",
     "        dtrain,\n",
     "        num_boost_round=2000,\n",
     "        valid_sets=[dval],\n",
     "        callbacks=[lgb.early_stopping(50, verbose=False)],\n",
     "    )\n",
     "    pc = m.predict(X_va)\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"lgb\", \"target\": \"COGS\", \"mape\": mape_cv(y_va[\"COGS\"], pc)})\n",
     "\n",
     "    # XGBoost Revenue\n",
     "    dtrain = xgb.DMatrix(X_tr, label=yl_tr[\"Revenue\"])\n",
     "    dval = xgb.DMatrix(X_va, label=yl_va[\"Revenue\"])\n",
     "    m = xgb.train(\n",
     "        {**xgb_base_params, **xgb_best_params_rev},\n",
     "        dtrain,\n",
     "        num_boost_round=800,\n",
     "        evals=[(dval, \"val\")],\n",
     "        early_stopping_rounds=50,\n",
     "        verbose_eval=False,\n",
     "    )\n",
     "    pr = np.maximum(np.expm1(m.predict(dval)), 0.0)\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"xgb\", \"target\": \"Revenue\", \"mape\": mape_cv(y_va[\"Revenue\"], pr)})\n",
     "\n",
     "    # XGBoost COGS\n",
     "    dtrain = xgb.DMatrix(X_tr, label=y_tr[\"COGS\"])\n",
     "    dval = xgb.DMatrix(X_va, label=y_va[\"COGS\"])\n",
     "    m = xgb.train(\n",
     "        {**xgb_base_params, **xgb_best_params_cogs},\n",
     "        dtrain,\n",
     "        num_boost_round=800,\n",
     "        evals=[(dval, \"val\")],\n",
     "        early_stopping_rounds=50,\n",
     "        verbose_eval=False,\n",
     "    )\n",
     "    pc = m.predict(dval)\n",
     "    cv_records.append({\"fold\": fold, \"model\": \"xgb\", \"target\": \"COGS\", \"mape\": mape_cv(y_va[\"COGS\"], pc)})\n",
     "\n",
     "cv_df = pd.DataFrame(cv_records)\n",
     "cv_summary = cv_df.groupby([\"model\", \"target\"])[\"mape\"].agg([\"mean\", \"std\"]).reset_index()\n",
     "\n",
     "single_split = pd.DataFrame([\n",
     "    {\"model\": \"rf\", \"target\": \"Revenue\", \"single_mape\": mape_cv(y_val[\"Revenue\"], val_pred[\"Revenue\"])},\n",
     "    {\"model\": \"rf\", \"target\": \"COGS\", \"single_mape\": mape_cv(y_val[\"COGS\"], val_pred[\"COGS\"])},\n",
     "    {\"model\": \"lgb\", \"target\": \"Revenue\", \"single_mape\": mape_cv(y_val[\"Revenue\"], val_pred_lgb_revenue)},\n",
     "    {\"model\": \"lgb\", \"target\": \"COGS\", \"single_mape\": mape_cv(y_val[\"COGS\"], val_pred_lgb_cogs)},\n",
     "    {\"model\": \"xgb\", \"target\": \"Revenue\", \"single_mape\": mape_cv(y_val[\"Revenue\"], xgb_val_pred[\"Revenue\"])},\n",
     "    {\"model\": \"xgb\", \"target\": \"COGS\", \"single_mape\": mape_cv(y_val[\"COGS\"], xgb_val_pred[\"COGS\"])},\n",
     "    {\"model\": \"et\", \"target\": \"Revenue\", \"single_mape\": mape_cv(y_val[\"Revenue\"], et_val_pred[\"Revenue\"])},\n",
     "    {\"model\": \"et\", \"target\": \"COGS\", \"single_mape\": mape_cv(y_val[\"COGS\"], et_val_pred[\"COGS\"])},\n",
     "])\n",
     "\n",
     "compare = cv_summary.merge(single_split, on=[\"model\", \"target\"])\n",
     "compare[\"model_target\"] = compare[\"model\"] + \"_\" + compare[\"target\"]\n",
     "compare = compare.sort_values(\"mean\").reset_index(drop=True)\n",
     "\n",
     "print(\"Mean ± Std MAPE across 5 TimeSeries folds vs Single Split:\")\n",
     "display(compare[[\"model_target\", \"mean\", \"std\", \"single_mape\"]].round(4))\n",
     "\n",
     "fig, ax = plt.subplots(figsize=(10, 5))\n",
     "x_pos = np.arange(len(compare))\n",
     "ax.errorbar(x_pos, compare[\"mean\"], yerr=compare[\"std\"], fmt=\"o\", capsize=5, label=\"CV (5-fold)\")\n",
     "ax.scatter(x_pos, compare[\"single_mape\"], color=\"red\", marker=\"x\", s=100, label=\"Single Split\")\n",
     "ax.set_xticks(x_pos)\n",
     "ax.set_xticklabels(compare[\"model_target\"], rotation=45, ha=\"right\")\n",
     "ax.set_ylabel(\"MAPE\")\n",
     "ax.set_title(\"CV vs Single-Split MAPE\")\n",
     "ax.legend()\n",
     "ax.grid(axis=\"y\", alpha=0.3)\n",
     "plt.tight_layout()\n",
     "plt.show()"\n",
     "    ]\n",
     "   },\n",
