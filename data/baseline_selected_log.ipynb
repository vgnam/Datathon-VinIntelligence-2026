   "source": [
    "required = ['rf_full', 'lgb_revenue_full', 'lgb_cogs_full', 'xgb_revenue_full', 'xgb_cogs_full', 'et_full', 'X_full']\n",
    "missing = [name for name in required if name not in globals()]\n",
    "if missing:\n",
    "    raise ValueError('Missing variables: {}. Run Sections 8-11 first.'.format(', '.join(missing)))\n",
    "\n",
    "feature_names = list(X_full.columns)\n",
    "\n",
    "importances = pd.DataFrame({'feature': feature_names})\n",
    "\n",
    "# Random Forest\n",
    "importances['rf'] = rf_full.feature_importances_\n",
    "\n",
    "# LightGBM - average gain importance across Revenue and COGS models\n",
    "lgb_rev_imp = pd.Series(lgb_revenue_full.feature_importance(importance_type='gain'), index=feature_names)\n",
    "lgb_cogs_imp = pd.Series(lgb_cogs_full.feature_importance(importance_type='gain'), index=feature_names)\n",
    "importances['lgb'] = (lgb_rev_imp + lgb_cogs_imp).values / 2.0\n",
    "\n",
    "# XGBoost - map fN indices to feature names (fallback for raw names)\n",
    "def xgb_importance_series(model):\n",
    "    scores = model.get_score(importance_type='gain')\n",
    "    mapped = {}\n",
    "    for k, v in scores.items():\n",
    "        if k.startswith('f') and k[1:].isdigit():\n",
    "            idx = int(k[1:])\n",
    "            mapped[feature_names[idx]] = v\n",
    "        else:\n",
    "            mapped[k] = v\n",
    "    s = pd.Series(mapped)\n",
    "    s = s.reindex(feature_names, fill_value=0.0)\n",
    "    return s\n",
    "\n",
    "xgb_rev_imp = xgb_importance_series(xgb_revenue_full)\n",
    "xgb_cogs_imp = xgb_importance_series(xgb_cogs_full)\n",
    "importances['xgb'] = (xgb_rev_imp + xgb_cogs_imp).values / 2.0\n",
    "\n",
    "# ExtraTrees\n",
    "importances['et'] = et_full.feature_importances_\n",
    "\n",
    "# Normalize each model to sum to 1\n",
    "for col in ['rf', 'lgb', 'xgb', 'et']:\n",
    "    total = importances[col].sum()\n",
    "    if total > 0:\n",
    "        importances[col] = importances[col] / total\n",
    "\n",
    "importances['mean'] = importances[['rf', 'lgb', 'xgb', 'et']].mean(axis=1)\n",
    "importances = importances.sort_values('mean', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print('Top 15 features by average normalized importance:')\n",
    "display(importances.head(15))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "top_n = 20\n",
    "plot_df = importances.head(top_n).copy()\n",
    "plot_df = plot_df.sort_values('mean', ascending=True)\n",
    "plot_df.set_index('feature')[['rf', 'lgb', 'xgb', 'et']].plot(kind='barh', ax=ax)\n",
    "ax.set_title(f'Top {top_n} Feature Importances (normalized)')\n",
    "ax.set_xlabel('Normalized Importance')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
